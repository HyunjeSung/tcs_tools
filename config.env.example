# tcs_tools 환경 설정
# 사용법: cp config.env.example config.env 후 본인 환경에 맞게 값 수정
# config.env 는 .gitignore 처리되어 git에 올라가지 않음 (경로가 사용자마다 다르므로)

# DUT(AC Gen2 EMS) IP — 랩 공용 리소스, 보통 팀 전체가 동일
DUT_HOST=192.168.10.25

# DUT SSH 접속용 키 (passphrase 제거된 사본) 경로 — WSL2 경로
SSH_KEY_PATH=~/.ssh/emsplus_mass_nopass

# DUT 시리얼 콘솔이 연결된 Windows COM 포트 — PC마다 다를 수 있음
SERIAL_COM_PORT=COM7

# passphrase 걸린 원본 SSH 키 경로 (Windows 경로, WSL 마운트 형식) — SSH_KEY_PATH 최초 생성 시에만 사용
WIN_KEY_PATH=C:\Users\<username>\Desktop\key\AC_GEN2\emsplus_mass

# 시리얼 helper 가 콘솔 로그를 쓰는 Windows 임시 파일 경로
WIN_TEMP_LOG_PATH=C:\Users\<username>\AppData\Local\Temp\tc_console.log
